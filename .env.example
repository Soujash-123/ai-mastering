# Copy this file to .env and set your values before running docker-compose.
OPENAI_API_KEY=your-openai-api-key-here

# Docker (recommended): leave empty and open the app at http://localhost (port 80).
# Nginx proxies /api and /ws to the backend — no cross-origin calls needed.
NEXT_PUBLIC_API_BASE=

# Local npm run dev only: point at the API directly
# NEXT_PUBLIC_API_BASE=http://localhost:8000
