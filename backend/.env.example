OPENAI_API_KEY=your_openai_api_key_here
# Model for mastering reasoning (set to gpt-5.1 when available on your account)
OPENAI_MASTERING_MODEL=gpt-4.1

# Paths
AI_MASTERING_DATA_DIR=./data

# Auth / database
DATABASE_URL=sqlite:///./data/app.db
JWT_SECRET_KEY=replace_with_secure_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
